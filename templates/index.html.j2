<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Marimo Notebooks</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['"IBM Plex Sans"', 'system-ui', 'sans-serif'],
            mono: ['"IBM Plex Mono"', 'monospace'],
          },
          colors: {
            navy: { 900: '#0c1629', 800: '#162040', 700: '#1e2f5a' },
            ocean: { 500: '#2b7fff', 400: '#60a5fa' },
            teal: { 500: '#0d9488', 400: '#2dd4bf' },
          }
        }
      }
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'IBM Plex Sans', system-ui, sans-serif; }
    .card-hover { transition: transform 0.15s ease, box-shadow 0.15s ease; }
    .card-hover:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.09); }
  </style>
</head>
<body class="bg-slate-50 text-slate-800 min-h-screen">

  <!-- Top nav bar -->
  <div class="bg-[#0c1629] border-b border-slate-700">
    <div class="max-w-5xl mx-auto px-6 py-3 flex items-center gap-3">
      <img src="https://raw.githubusercontent.com/marimo-team/marimo/main/docs/_static/marimo-logotype-thick.svg"
           alt="marimo" class="h-5 brightness-0 invert opacity-90">
      <span class="text-slate-400 text-sm font-mono">/ notebooks</span>
    </div>
  </div>

  <!-- Hero -->
  <div class="bg-[#162040] text-white">
    <div class="max-w-5xl mx-auto px-6 py-14">
      <p class="text-xs font-mono text-sky-400 uppercase tracking-widest mb-3">tayden / marimo-notebooks</p>
      <h1 class="text-3xl font-semibold tracking-tight mb-3">Notebook Showcase</h1>
      <p class="text-slate-300 text-base max-w-xl leading-relaxed">
        A collection of interactive notebooks and applications built with marimo, covering tidal analysis, projector calibration, and geospatial tooling.
      </p>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-6 py-12 space-y-14">

    {% if apps %}
    <!-- Apps section -->
    <section>
      <div class="flex items-center gap-3 mb-1">
        <h2 class="text-lg font-semibold text-slate-900">Apps</h2>
        <span class="bg-blue-50 text-blue-700 text-xs font-mono px-2 py-0.5 rounded-full border border-blue-200">run mode</span>
      </div>
      <p class="text-sm text-slate-500 mb-6">Deployed as standalone applications — code is hidden, UI is front and center.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {% for app in apps %}
        <a href="{{ app.html_path }}" class="card-hover group block bg-white rounded-xl border border-slate-200 overflow-hidden no-underline">
          <div class="h-1 bg-gradient-to-r from-blue-400 to-blue-600"></div>
          <div class="p-5">
            <p class="font-medium text-slate-800 text-sm leading-snug mb-4 group-hover:text-blue-700 transition-colors">{{ app.display_name }}</p>
            <div class="flex items-center gap-1.5 text-xs text-blue-600 font-medium">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
              Open App
            </div>
          </div>
        </a>
        {% endfor %}
      </div>
    </section>
    {% endif %}

    {% if notebooks %}
    <!-- Notebooks section -->
    <section>
      <div class="flex items-center gap-3 mb-1">
        <h2 class="text-lg font-semibold text-slate-900">Notebooks</h2>
        <span class="bg-teal-50 text-teal-700 text-xs font-mono px-2 py-0.5 rounded-full border border-teal-200">edit mode</span>
      </div>
      <p class="text-sm text-slate-500 mb-6">Source notebooks — code is visible and editable directly in the browser.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {% for notebook in notebooks %}
        <a href="{{ notebook.html_path }}" class="card-hover group block bg-white rounded-xl border border-slate-200 overflow-hidden no-underline">
          <div class="h-1 bg-gradient-to-r from-teal-400 to-teal-600"></div>
          <div class="p-5">
            <p class="font-medium text-slate-800 text-sm leading-snug mb-4 group-hover:text-teal-700 transition-colors">{{ notebook.display_name }}</p>
            <div class="flex items-center gap-1.5 text-xs text-teal-600 font-medium">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
              Open Notebook
            </div>
          </div>
        </a>
        {% endfor %}
      </div>
    </section>
    {% endif %}

  </div>

  <!-- Footer -->
  <footer class="border-t border-slate-200 mt-8">
    <div class="max-w-5xl mx-auto px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-slate-400">
      <p>Built with <a href="https://marimo.io" target="_blank" class="text-slate-600 hover:text-slate-900 underline underline-offset-2">marimo</a> · Deployed on GitHub Pages</p>
      <div class="flex items-center gap-5">
        <a href="https://github.com/marimo-team/marimo" target="_blank" class="hover:text-slate-700 transition-colors">GitHub</a>
        <a href="https://docs.marimo.io" target="_blank" class="hover:text-slate-700 transition-colors">Docs</a>
        <a href="https://discord.gg/JE7nhX6mD8" target="_blank" class="hover:text-slate-700 transition-colors">Discord</a>
      </div>
    </div>
  </footer>

</body>
</html>
